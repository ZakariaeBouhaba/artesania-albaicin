# Payload CMS — copy to .env and fill in your values

NODE_ENV=development

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=change-me-to-a-64-char-random-string

# Separate database from the Express backend (avoids table name collisions)
DATABASE_URL=postgresql://DB_USER:DB_PASS@localhost:5432/artisania_cms

# URLs
PAYLOAD_SERVER_URL=http://localhost:3002
FRONTEND_URL=http://localhost:5175
EXPRESS_URL=http://localhost:3001

# Disable Next.js telemetry
NEXT_TELEMETRY_DISABLED=1
